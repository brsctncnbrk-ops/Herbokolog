# Anthropic Claude API anahtarı.
# BOŞ bırakılırsa sistem otomatik olarak deterministik anahtar-kelime tabanlı
# yedek analiz katmanına düşer (demo bu sayede anahtarsız da çalışır).
ANTHROPIC_API_KEY=

# Veritabanı bağlantısı (SQLite demo için).
DATABASE_URL="file:./dev.db"

# Cron job'larını korumak için gizli anahtar (Authorization: Bearer <CRON_SECRET>).
CRON_SECRET="degistir-bu-cron-gizli-anahtarini"

# Admin paneli giriş şifresi (/admin).
ADMIN_PASSWORD="degistir-bu-admin-sifresini"

# Admin oturum çerezini imzalamak için gizli anahtar.
ADMIN_SESSION_SECRET="degistir-bu-oturum-imza-anahtarini"
