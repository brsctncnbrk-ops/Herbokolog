# --- Veritabanı (PostgreSQL — zorunlu) ---
# Neon / Vercel Postgres / Supabase bağlantı dizesi.
# Neon örneği:
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Anthropic Claude API ---
# Boş bırakılırsa keyword tabanlı yedek analiz devreye girer.
# Production'da gerçek analiz için doldurun.
ANTHROPIC_API_KEY=

# --- Güvenlik (production'da güçlü değerler ZORUNLU) ---
# Cron route'larını korur: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="uzun-rastgele-bir-deger-uretin"
# Admin paneli (/admin) giriş şifresi
ADMIN_PASSWORD="guclu-bir-admin-sifresi"
# Admin oturum çerezini imzalar (en az 16, tercihen 32+ karakter)
ADMIN_SESSION_SECRET="en-az-32-karakterlik-rastgele-gizli-anahtar"

# --- Rate limit (opsiyonel; yoksa in-memory'ye düşer) ---
# Sunucusuzda (Vercel) instance'lar arası tutarlılık için Upstash Redis.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
